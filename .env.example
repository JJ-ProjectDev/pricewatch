COMPOSE_PROJECT_NAME=pricewatch

WEB_PORT=5173
API_GATEWAY_PORT=3000

POSTGRES_DB=pricewatch
POSTGRES_USER=pricewatch
POSTGRES_PASSWORD=pricewatch_dev_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://pricewatch:pricewatch_dev_password@postgres:5432/pricewatch
LOCAL_DATABASE_URL=postgresql://pricewatch:pricewatch_dev_password@localhost:5432/pricewatch

JWT_SECRET=pricewatch_dev_jwt_secret_change_me
JWT_EXPIRES_IN=15m

REDIS_PORT=6379
REDIS_URL=redis://redis:6379

RABBITMQ_DEFAULT_USER=pricewatch
RABBITMQ_DEFAULT_PASS=pricewatch_dev_password
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_URL=amqp://pricewatch:pricewatch_dev_password@rabbitmq:5672
